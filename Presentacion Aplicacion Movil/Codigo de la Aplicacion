import { useState, useEffect } from "react";
import { useNavigate } from "react-router";
import { Battery, Wifi, WifiOff, LogOut, AlertTriangle, Power, Activity } from "lucide-react";

interface ActivityEvent {
  id: string;
  time: string;
  event: string;
  type: "success" | "info" | "warning" | "error";
}

export function Dashboard() {
  const [isConnected, setIsConnected] = useState(true);
  const [batteryLevel, setBatteryLevel] = useState(100);
  const [activities, setActivities] = useState<ActivityEvent[]>([
    { id: "1", time: new Date().toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' }), event: "Sistema iniciado", type: "success" },
    { id: "2", time: new Date().toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' }), event: "Dispositivo conectado exitosamente", type: "success" },
    { id: "3", time: new Date().toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' }), event: "Nivel de batería: 100%", type: "info" },
  ]);
  const [lastBatteryAlert, setLastBatteryAlert] = useState(100);
  const navigate = useNavigate();

  // Función para agregar nueva actividad
  const addActivity = (event: string, type: ActivityEvent["type"]) => {
    const newActivity: ActivityEvent = {
      id: Date.now().toString(),
      time: new Date().toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' }),
      event,
      type,
    };
    setActivities((prev) => [newActivity, ...prev].slice(0, 8)); // Mantener solo las últimas 8
  };

  useEffect(() => {
    // Verificar autenticación
    const isAuth = localStorage.getItem("isAuthenticated");
    if (!isAuth) {
      navigate("/");
    }

    // Simulación de cambios de estado
    const interval = setInterval(() => {
      // Simulación de nivel de batería que disminuye gradualmente
      setBatteryLevel((prev) => {
        const newLevel = prev - Math.random() * 2;
        return newLevel > 0 ? newLevel : 0;
      });

      // Simulación aleatoria de conexión/desconexión
      if (Math.random() > 0.9) {
        setIsConnected((prev) => !prev);
      }
    }, 3000);

    return () => clearInterval(interval);
  }, [navigate]);

  const handleLogout = () => {
    localStorage.removeItem("isAuthenticated");
    navigate("/");
  };

  const getBatteryColor = () => {
    if (batteryLevel > 60) return "text-green-700";
    if (batteryLevel > 30) return "text-yellow-700";
    return "text-red-700";
  };

  const getBatteryBgColor = () => {
    if (batteryLevel > 60) return "bg-green-600";
    if (batteryLevel > 30) return "bg-yellow-600";
    return "bg-red-600";
  };

  const getBatteryStatus = () => {
    if (batteryLevel > 60) return "ÓPTIMO";
    if (batteryLevel > 30) return "MODERADO";
    return "CRÍTICO";
  };

  // Monitorear cambios en el nivel de batería
  useEffect(() => {
    const roundedLevel = Math.round(batteryLevel);
    
    // Alerta cuando baja del 80%
    if (roundedLevel <= 80 && lastBatteryAlert > 80) {
      addActivity(`Nivel de batería: ${roundedLevel}% - Descargando`, "info");
      setLastBatteryAlert(80);
    }
    // Alerta cuando baja del 60%
    else if (roundedLevel <= 60 && lastBatteryAlert > 60) {
      addActivity(`⚠️ Batería al ${roundedLevel}% - Nivel moderado`, "warning");
      setLastBatteryAlert(60);
    }
    // Alerta cuando baja del 30%
    else if (roundedLevel <= 30 && lastBatteryAlert > 30) {
      addActivity(`⚠️ ALERTA: Batería baja ${roundedLevel}%`, "warning");
      setLastBatteryAlert(30);
    }
    // Alerta cuando baja del 20%
    else if (roundedLevel <= 20 && lastBatteryAlert > 20) {
      addActivity(`🚨 CRÍTICO: Batería al ${roundedLevel}%`, "error");
      setLastBatteryAlert(20);
    }
    // Alerta cuando baja del 15%
    else if (roundedLevel <= 15 && lastBatteryAlert > 15) {
      addActivity(`🚨 URGENTE: Batería crítica ${roundedLevel}%`, "error");
      setLastBatteryAlert(15);
    }
  }, [batteryLevel, lastBatteryAlert]);

  // Monitorear cambios en la conexión
  useEffect(() => {
    if (isConnected) {
      addActivity("Dispositivo conectado exitosamente", "success");
    } else {
      addActivity("⚠️ Dispositivo desconectado", "error");
    }
  }, [isConnected]);

  // Redirigir a pantalla de emergencia cuando batería crítica
  useEffect(() => {
    if (batteryLevel < 15) {
      navigate("/alert");
    }
  }, [batteryLevel, navigate]);

  return (
    <div className="size-full bg-gray-100 overflow-auto">
      {/* Header - Alto contraste */}
      <header className="bg-gray-900 shadow-lg sticky top-0 z-10">
        <div className="px-4 sm:px-6 py-4 flex justify-between items-center">
          <div>
            <h1 className="text-2xl sm:text-3xl font-bold text-white">Dashboard</h1>
            <p className="text-base text-gray-300 mt-1">Sistema de Monitoreo</p>
          </div>
          <button
            onClick={handleLogout}
            className="flex items-center gap-2 h-12 px-6 bg-red-600 hover:bg-red-700 active:bg-red-800 text-white font-bold rounded-xl transition-colors shadow-lg focus:ring-4 focus:ring-red-300"
            aria-label="Cerrar sesión"
          >
            <LogOut className="w-5 h-5" strokeWidth={2.5} />
            <span className="hidden sm:inline">Salir</span>
          </button>
        </div>
      </header>

      {/* Main Content */}
      <main className="p-4 sm:p-6 max-w-6xl mx-auto">
        <div className="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6">
          
          {/* Estado de Conexión - Card grande con alto contraste */}
          <div className="bg-white rounded-2xl shadow-2xl border-4 border-gray-900 overflow-hidden">
            {/* Header de la card */}
            <div className={`p-6 ${isConnected ? "bg-green-600" : "bg-red-600"}`}>
              <div className="flex items-center justify-between">
                <h2 className="text-2xl font-bold text-white">Conexión</h2>
                {isConnected ? (
                  <Wifi className="w-10 h-10 text-white" strokeWidth={2.5} />
                ) : (
                  <WifiOff className="w-10 h-10 text-white" strokeWidth={2.5} />
                )}
              </div>
            </div>

            {/* Contenido de la card */}
            <div className="p-6 space-y-6">
              {/* Estado grande y visible */}
              <div className="text-center py-6">
                <div className={`text-6xl font-bold mb-2 ${isConnected ? "text-green-700" : "text-red-700"}`}>
                  {isConnected ? "CONECTADO" : "DESCONECTADO"}
                </div>
                <div className="flex items-center justify-center gap-2 mt-4">
                  <Activity className={`w-6 h-6 ${isConnected ? "text-green-700 animate-pulse" : "text-red-700"}`} />
                  <span className="text-xl font-semibold text-gray-900">
                    {isConnected ? "Sistema activo" : "Sin conexión"}
                  </span>
                </div>
              </div>

              {/* Información del dispositivo */}
              <div className="bg-gray-100 rounded-xl p-6 border-2 border-gray-900">
                <h3 className="font-bold text-lg text-gray-900 mb-4">Información</h3>
                <div className="space-y-3">
                  <div className="flex justify-between items-center">
                    <span className="text-base font-semibold text-gray-700">Dispositivo:</span>
                    <span className="text-base font-bold text-gray-900">Device-001</span>
                  </div>
                  <div className="flex justify-between items-center">
                    <span className="text-base font-semibold text-gray-700">IP:</span>
                    <span className="text-base font-bold text-gray-900">192.168.1.100</span>
                  </div>
                  <div className="flex justify-between items-center">
                    <span className="text-base font-semibold text-gray-700">Última conexión:</span>
                    <span className="text-base font-bold text-gray-900">
                      {new Date().toLocaleTimeString('es-ES')}
                    </span>
                  </div>
                </div>
              </div>

              {/* Botón grande de acción */}
              <button
                onClick={() => setIsConnected(!isConnected)}
                className={`w-full h-16 rounded-xl font-bold text-xl transition-all shadow-lg focus:ring-4 ${
                  isConnected
                    ? "bg-red-600 hover:bg-red-700 active:bg-red-800 text-white focus:ring-red-300"
                    : "bg-green-600 hover:bg-green-700 active:bg-green-800 text-white focus:ring-green-300"
                }`}
                aria-label={isConnected ? "Desconectar dispositivo" : "Conectar dispositivo"}
              >
                <Power className="w-6 h-6 inline mr-2" strokeWidth={2.5} />
                {isConnected ? "DESCONECTAR" : "CONECTAR"}
              </button>
            </div>
          </div>

          {/* Nivel de Batería - Card grande con alto contraste */}
          <div className="bg-white rounded-2xl shadow-2xl border-4 border-gray-900 overflow-hidden">
            {/* Header de la card */}
            <div className={`p-6 ${getBatteryBgColor()}`}>
              <div className="flex items-center justify-between">
                <h2 className="text-2xl font-bold text-white">Batería</h2>
                <Battery className="w-10 h-10 text-white" strokeWidth={2.5} />
              </div>
            </div>

            {/* Contenido de la card */}
            <div className="p-6 space-y-6">
              {/* Porcentaje grande y visible */}
              <div className="text-center py-6">
                <div className={`text-7xl font-bold mb-2 ${getBatteryColor()}`}>
                  {Math.round(batteryLevel)}%
                </div>
                <div className={`text-3xl font-bold ${getBatteryColor()}`}>
                  {getBatteryStatus()}
                </div>
              </div>

              {/* Barra de progreso grande */}
              <div className="w-full bg-gray-200 rounded-full h-12 overflow-hidden border-3 border-gray-900">
                <div
                  className={`h-full ${getBatteryBgColor()} transition-all duration-500 flex items-center justify-end pr-4`}
                  style={{ width: `${batteryLevel}%` }}
                >
                  {batteryLevel > 15 && (
                    <span className="text-base text-white font-bold">
                      {Math.round(batteryLevel)}%
                    </span>
                  )}
                </div>
              </div>

              {/* Información adicional */}
              <div className="bg-gray-100 rounded-xl p-6 border-2 border-gray-900">
                <div className="space-y-3">
                  <div className="flex justify-between items-center">
                    <span className="text-base font-semibold text-gray-700">Tiempo estimado:</span>
                    <span className="text-base font-bold text-gray-900">
                      {Math.round(batteryLevel / 10)} horas
                    </span>
                  </div>
                  <div className="flex justify-between items-center">
                    <span className="text-base font-semibold text-gray-700">Estado:</span>
                    <span className="text-base font-bold text-gray-900">
                      {batteryLevel < 95 ? "En descarga" : "Completa"}
                    </span>
                  </div>
                </div>
              </div>

              {/* Alerta de batería baja - Alto contraste */}
              {batteryLevel < 30 && (
                <div className="flex items-start gap-3 p-5 bg-yellow-400 border-4 border-yellow-700 rounded-xl">
                  <AlertTriangle className="w-7 h-7 text-yellow-900 flex-shrink-0 mt-0.5" strokeWidth={2.5} />
                  <div>
                    <p className="text-base font-bold text-yellow-900 mb-1">
                      ⚠️ BATERÍA BAJA
                    </p>
                    <p className="text-sm font-semibold text-yellow-900">
                      Conecte el dispositivo a la corriente pronto.
                    </p>
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>

        {/* Panel de Actividad - Alto contraste */}
        <div className="mt-6 bg-white rounded-2xl shadow-2xl border-4 border-gray-900 p-6">
          <h2 className="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-2">
            <Activity className="w-7 h-7" strokeWidth={2.5} />
            Actividad Reciente
          </h2>
          <div className="space-y-3">
            {activities.map((activity) => (
              <div
                key={activity.id}
                className="flex items-center gap-4 p-4 bg-gray-100 border-2 border-gray-300 rounded-xl hover:border-gray-900 transition-all min-h-[60px]"
              >
                <span className="text-base font-bold text-gray-900 min-w-[60px]">
                  {activity.time}
                </span>
                <div
                  className={`w-4 h-4 rounded-full border-2 flex-shrink-0 ${
                    activity.type === "success" 
                      ? "bg-green-600 border-green-800" 
                      : activity.type === "warning"
                      ? "bg-yellow-500 border-yellow-700"
                      : activity.type === "error"
                      ? "bg-red-600 border-red-800"
                      : "bg-blue-600 border-blue-800"
                  }`}
                />
                <span className={`text-base font-semibold ${
                  activity.type === "error" ? "text-red-700" : 
                  activity.type === "warning" ? "text-yellow-800" : 
                  "text-gray-900"
                }`}>
                  {activity.event}
                </span>
              </div>
            ))}
          </div>
        </div>
      </main>
    </div>
  );
}
